{
  "name": "evee",
  "version": "1.0.2",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild": "npx expo prebuild --skip-dependency-update react-native,react",
    "prebuild:clean": "npx expo prebuild --clean",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios --auto-submit",
    "build:ios:local": "rm -rf ./*-*.ipa && eas build --local --platform ios --non-interactive && eas submit --platform ios --path $(ls build-*.ipa) --non-interactive",
    "update:development": "eas update --channel development --message \"Development update\"",
    "update:preview": "eas update --channel preview --message \"Preview update\"",
    "update:production": "eas update --channel production --message \"Production update\"",
    "update:production:ios": "eas update --channel production --message \"Production update\" --platform ios",
    "update:production:android": "eas update --channel production --message \"Production update\" --platform android"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.7.0",
    "@elevenlabs/react-native": "^0.5.11",
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@livekit/react-native": "^2.9.6",
    "@livekit/react-native-expo-plugin": "^1.0.1",
    "@livekit/react-native-webrtc": "^137.0.2",
    "@lodev09/react-native-true-sheet": "^3.9.7",
    "@react-native-firebase/analytics": "^21.6.2",
    "@react-native-firebase/app": "^21.6.2",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "@tabler/icons-react-native": "^3.37.1",
    "axios": "^1.15.1",
    "dotenv": "^17.4.2",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "^15.0.8",
    "expo-image": "^3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "livekit-client": "^2.17.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-appsflyer": "^6.17.9",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.10.4",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "^0.7.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
